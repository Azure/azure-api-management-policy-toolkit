<policies>
	<inbound>
		<base />
		<cache-lookup vary-by-developer="false" vary-by-developer-groups="false">
			<vary-by-query-parameter>locale</vary-by-query-parameter>
			<vary-by-header>Accept</vary-by-header>
			<vary-by-header>Accept-Charset</vary-by-header>
		</cache-lookup>
	</inbound>
	<backend>
		<base />
	</backend>
	<outbound>
		<base />
		<cache-store duration="14400" />
	</outbound>
	<on-error>
		<base />
	</on-error>
</policies>