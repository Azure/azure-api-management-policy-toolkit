<policies>
	<inbound>
		<base />
		<publish-to-darp topic="my-topic" pub-sub-name="my-pubsub" ignore-error="false" response-variable-name="darpResponse" timeout="60" template="my-template" content-type="application/json">@(context.Request.Body.As&lt;string&gt;())</publish-to-darp>
	</inbound>
	<backend>
		<base />
	</backend>
	<outbound>
		<base />
	</outbound>
	<on-error>
		<base />
	</on-error>
</policies>