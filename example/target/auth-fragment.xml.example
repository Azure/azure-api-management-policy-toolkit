<!-- This file is generated by the Azure API Management Policy Toolkit -->
<!-- Version: 1.0.0.0 -->
<fragment>
  <set-header name="X-Auth-Fragment">
    <value>@(context.Variables.GetValueOrDefault<string>("auth-fragment-xauth", "false"))</value>
  </set-header>
  <authentication-basic username="{{username}}" password="{{password}}" />
</fragment>