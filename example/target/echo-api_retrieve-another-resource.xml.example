<!-- This file is generated by the Azure API Management Policy Toolkit -->
<!-- Version: 1.0.0.0 -->
<policies>
  <inbound>
    <base />
    <choose>
      <when condition="@(context.Request.IpAddress.StartsWith("10.0.0."))">
        <set-variable name="auth-fragment-xauth" value="true" />
        <include-fragment fragment-id="auth-fragment" />
      </when>
      <otherwise>
        <authentication-managed-identity resource="https://management.azure.com/" />
      </otherwise>
    </choose>
  </inbound>
</policies>